[Unit]
Description=Arithmetics SOAP Web Service
After=network.target

[Service]
Type=simple
User={{ service_user }}
WorkingDirectory={{ service_dir }}
ExecStart=/usr/bin/java -Xms64m -Xmx256m -jar {{ jar_path }}
Restart=on-failure
RestartSec=5s
StandardOutput=journal
StandardError=journal
SyslogIdentifier=arithmetics

[Install]
WantedBy=multi-user.target
